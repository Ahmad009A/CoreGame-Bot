# ═══════════════════════════════════════════════
#         CORE GAME BOT — ENVIRONMENT CONFIG
# ═══════════════════════════════════════════════

# ── Discord Bot Credentials ──────────────────
BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# ── Discord OAuth2 (Dashboard Login) ─────────
CLIENT_SECRET=your_client_secret_here
CALLBACK_URL=http://localhost:3000/auth/callback

# ── Database ─────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/coregame

# ── Channel IDs ──────────────────────────────
WELCOME_CHANNEL_ID=your_welcome_channel_id
LOG_CHANNEL_ID=your_log_channel_id

# ── Role IDs ─────────────────────────────────
STAFF_ROLE_ID=your_staff_role_id
ADMIN_ROLE_ID=your_admin_role_id

# ── Web Dashboard ────────────────────────────
DASHBOARD_PORT=3000
SESSION_SECRET=generate-a-random-secret-string-here

# ── System Settings ──────────────────────────
BOT_USE_CHANNEL_NAME=bot-use
VIP_TRIGGER_CHANNEL_NAME=VIP Room
SPIN_COOLDOWN_HOURS=24
